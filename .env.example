# Vercel Postgres (Neon) — wird von Vercel automatisch gesetzt nach Integration
POSTGRES_URL=

# Admin-Passwort für /admin
ADMIN_PASSWORD=dein-sicheres-passwort

# Session-Secret — mind. 32 zufällige Zeichen
# Generieren: openssl rand -base64 32
SESSION_SECRET=min-32-zeichen-langes-zufaelliges-secret-hier
